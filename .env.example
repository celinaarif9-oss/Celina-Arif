# Copy to .env and fill in real values. NEVER commit .env.
# See CLAUDE.md → "Security & data" and "Least privilege".
# Default to read-only scopes; write-capable access is used ONLY behind a Human Approval gate.

# --- Shopify Admin API (custom app) ---
# Core scopes: read_orders, read_products. Add write_products ONLY for approved bulk updates.
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_API_VERSION=2024-10

# --- Google APIs (Sheets / Apps Script service account) ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_ORDERS_ID=

# --- Make.com ---
MAKE_WEBHOOK_URL=

# --- Meta (Phase 3 — ads reporting) ---
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# --- WhatsApp BSP (Phase 4 — Interakt / AiSensy / Wati) ---
WHATSAPP_BSP_API_KEY=
WHATSAPP_BSP_BASE_URL=
